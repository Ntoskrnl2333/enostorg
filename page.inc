"<!DOCTYPE html>\n"
"<html lang=\"zh-CN\">\n"
"<head><meta charset=\"UTF-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1.0\">\n"
"<title>Enostorg - Network Storage</title>\n"
"<style>\n"
"*{box-sizing:border-box;margin:0;padding:0}\n"
"body{font-family:-apple-system,BlinkMacSystemFont,\"Segoe UI\",Roboto,sans-serif;background:#f5f5f5;color:#333}\n"
"h1{padding:16px 24px;background:#2c3e50;color:#fff;font-size:20px}\n"
".layout{display:flex;gap:16px;padding:16px;max-width:1400px;margin:0 auto}\n"
".panel{background:#fff;border-radius:8px;box-shadow:0 1px 3px rgba(0,0,0,.1);flex:1;padding:16px;min-width:0}\n"
".panel h2{font-size:16px;margin-bottom:12px;padding-bottom:8px;border-bottom:2px solid #2c3e50}\n"
".form-row{display:flex;gap:8px;margin-bottom:8px;flex-wrap:wrap}\n"
".form-row input{flex:1;min-width:120px;padding:8px 10px;border:1px solid #ddd;border-radius:4px;font-size:14px}\n"
".form-row input[type=number]{width:100px;flex:0 0 auto}\n"
".btn{padding:8px 16px;border:none;border-radius:4px;cursor:pointer;font-size:14px}\n"
".btn-primary{background:#2c3e50;color:#fff}\n"
".btn-danger{background:#e74c3c;color:#fff}\n"
".btn-success{background:#27ae60;color:#fff}\n"
".btn-warning{background:#f39c12;color:#fff}\n"
".btn-small{padding:4px 10px;font-size:12px}\n"
".btn:hover{opacity:.85}\n"
"table{width:100%;border-collapse:collapse;margin-top:8px}\n"
"th,td{padding:8px 10px;text-align:left;border-bottom:1px solid #eee;font-size:13px}\n"
"th{background:#f8f8f8;font-weight:600}\n"
"tr:hover{background:#fafafa}\n"
".monospace{font-family:\"Cascadia Code\",\"Consolas\",monospace;font-size:12px;word-break:break-all}\n"
".badge{padding:2px 8px;border-radius:10px;font-size:11px}\n"
".badge-ok{background:#d4edda;color:#155724}\n"
".badge-bad{background:#f8d7da;color:#721c24}\n"
".msg{padding:8px 12px;border-radius:4px;margin-bottom:8px;font-size:14px;display:none}\n"
".msg-success{background:#d4edda;color:#155724}\n"
".msg-error{background:#f8d7da;color:#721c24}\n"
"</style></head>\n"
"<body>\n"
"<h1>Enostorg Network Storage</h1>\n"
"<div class=\"layout\">\n"
"<div class=\"panel\" style=\"flex:1\">\n"
"<h2>Create File</h2>\n"
"<div class=\"msg\" id=\"fmsg\"></div>\n"
"<div class=\"form-row\">\n"
"  <input id=\"ffpath\" placeholder=\"/path/to/file\">\n"
"  <input id=\"fsize\" type=\"number\" placeholder=\"Size (Bytes)\" value=\"1024\">\n"
"  <input id=\"fdesc\" placeholder=\"Description\">\n"
"</div>\n"
"<div class=\"form-row\"><button class=\"btn btn-primary\" onclick=\"createFile()\">Create File</button></div>\n"
"<h2>Files</h2>\n"
"<div id=\"filelist\"><table><tr><th>Path</th><th>Size</th><th>Description</th><th>Actions</th></tr></table></div>\n"
"</div>\n"
"<div class=\"panel\" style=\"flex:1\">\n"
"<h2>Create Block</h2>\n"
"<div class=\"msg\" id=\"bmsg\"></div>\n"
"<div class=\"form-row\">\n"
"  <input id=\"bpath\" placeholder=\"/blocks/001.bin\">\n"
"  <input id=\"bsha\" placeholder=\"SHA-256\">\n"
"  <input id=\"bsize\" type=\"number\" placeholder=\"Size\" value=\"4096\">\n"
"</div>\n"
"<div class=\"form-row\"><button class=\"btn btn-primary\" onclick=\"createBlock()\">Create Block</button></div>\n"
"<h2>Append Block to File</h2>\n"
"<div class=\"form-row\">\n"
"  <input id=\"atarget\" placeholder=\"File path\">\n"
"  <input id=\"ablock\" type=\"number\" placeholder=\"Block ID\">\n"
"  <button class=\"btn btn-success\" onclick=\"appendBlock()\">Append</button>\n"
"</div>\n"
"<h2>Blocks</h2>\n"
"<div class=\"form-row\">\n"
"  <input id=\"blockfilter\" placeholder=\"Filter by file path\" style=\"flex:1\">\n"
"  <button class=\"btn btn-primary\" onclick=\"loadBlocks()\">Load</button>\n"
"</div>\n"
"<div id=\"blocklist\"><table><tr><th>ID</th><th>Path</th><th>Size</th><th>Status</th><th>SHA-256</th><th>Actions</th></tr></table></div>\n"
"</div>\n"
"</div>\n"
"<script>\n"
"var API='/api';\n"
"function showMsg(el,text,cls){\n"
" el.textContent=text;el.className='msg msg-'+cls;el.style.display='block';\n"
" setTimeout(function(){el.style.display='none'},3000);}\n"
"function createFile(){\n"
" var fp=document.getElementById('ffpath').value.trim();\n"
" var sz=document.getElementById('fsize').value;\n"
" var d=document.getElementById('fdesc').value.trim();\n"
" var m=document.getElementById('fmsg');\n"
" if(!fp){showMsg(m,'File path required','error');return}\n"
" var b=JSON.stringify({file_path:fp,size:parseInt(sz),description:d});\n"
" fetch(API+'/files',{method:'POST',headers:{'Content-Type':'application/json'},body:b})\n"
" .then(function(r){return r.json()}).then(function(j){\n"
"  if(j.file_path){showMsg(m,'Created: '+j.file_path,'success');loadFiles()}\n"
"  else{showMsg(m,j.error,'error')}});}\n"
"function loadFiles(){\n"
" fetch(API+'/files').then(function(r){return r.json()}).then(function(files){\n"
"  var h='<table><tr><th>Path</th><th>Size</th><th>Description</th><th>Actions</th></tr>';\n"
"  for(var i=0;i<files.length;i++){\n"
"   var f=files[i];\n"
"   h+='<tr><td><span class=\"monospace\">'+esc(f.file_path)+'</span></td>';\n"
"   h+='<td>'+fmtSize(f.size)+'</td>';\n"
"   h+='<td>'+esc(f.description||'')+'</td>';\n"
"   h+='<td><button class=\"btn btn-small btn-primary\" onclick=\"loadBlocks(\\''+\n"
"    esc(f.file_path)+'\\')\">Blocks</button> ';\n"
"   h+='<button class=\"btn btn-small btn-danger\" onclick=\"delFile(\\''+\n"
"    esc(f.file_path)+'\\')\">Del</button></td></tr>';}\n"
"  h+='</table>';document.getElementById('filelist').innerHTML=h;});}\n"
"function delFile(p){\n"
" if(!confirm('Delete '+p+' and blocks?'))return;\n"
" fetch(API+'/files?path='+encodeURIComponent(p),{method:'DELETE'}).then(loadFiles);}\n"
"function createBlock(){\n"
" var bp=document.getElementById('bpath').value.trim();\n"
" var sh=document.getElementById('bsha').value.trim();\n"
" var sz=document.getElementById('bsize').value;\n"
" var m=document.getElementById('bmsg');\n"
" if(!bp||!sh){showMsg(m,'Path and SHA-256 needed','error');return}\n"
" var b=JSON.stringify({block_path:bp,sha256:sh,block_size:parseInt(sz)});\n"
" fetch(API+'/blocks',{method:'POST',headers:{'Content-Type':'application/json'},body:b})\n"
" .then(function(r){return r.json()}).then(function(j){\n"
"  if(typeof j.id!=='undefined'){showMsg(m,'Block #'+j.id+' created','success');\n"
"   loadBlocks()}else{showMsg(m,j.error,'error')}});\n"
" document.getElementById('bpath').value='';\n"
" document.getElementById('bsha').value='';}\n"
"function loadBlocks(fp){\n"
" if(fp)document.getElementById('blockfilter').value=fp;\n"
" var p=document.getElementById('blockfilter').value.trim();\n"
" fetch(API+'/files/blocks?path='+encodeURIComponent(p||'/'))\n"
" .then(function(r){return r.json()}).then(function(blocks){\n"
"  var h='<table><tr><th>ID</th><th>Path</th><th>Size</th><th>Status</th><th>SHA-256</th><th>Actions</th></tr>';\n"
"  for(var i=0;i<blocks.length;i++){\n"
"   var b=blocks[i];\n"
"   h+='<tr><td>'+b.id+'</td>';\n"
"   h+='<td><span class=\"monospace\">'+esc(b.block_path)+'</span></td>';\n"
"   h+='<td>'+fmtSize(b.block_size)+'</td>';\n"
"   h+='<td>'+(b.is_bad?'<span class=\"badge badge-bad\">BAD</span>':\n"
"    '<span class=\"badge badge-ok\">OK</span>')+'</td>';\n"
"   h+='<td><span class=\"monospace\" title=\"'+esc(b.sha256)+'\">'+\n"
"    esc(b.sha256).slice(0,16)+'...</span></td>';\n"
"   h+='<td><button class=\"btn btn-small btn-danger\" onclick=\"delBlock('+b.id+')\">Del</button> ';\n"
"   h+='<button class=\"btn btn-small btn-warning\" onclick=\"markBad('+b.id+')\">Bad</button></td></tr>';}\n"
"  h+='</table>';document.getElementById('blocklist').innerHTML=h;});}\n"
"function appendBlock(){\n"
" var fp=document.getElementById('atarget').value.trim();\n"
" var bid=document.getElementById('ablock').value;\n"
" fetch(API+'/files/blocks?path='+encodeURIComponent(fp)+'&block='+bid,{method:'POST'})\n"
" .then(function(r){if(r.ok){loadBlocks(fp);loadFiles()}\n"
"  else{r.json().then(function(j){alert(j.error)})}});}\n"
"function delBlock(id){\n"
" if(!confirm('Delete block #'+id+'?'))return;\n"
" fetch(API+'/blocks/delete?block='+id,{method:'DELETE'}).then(loadBlocks);}\n"
"function markBad(id){\n"
" fetch(API+'/blocks/bad?block='+id,{method:'PATCH'}).then(loadBlocks);}\n"
"function esc(s){\n"
" var d=document.createElement('div');d.appendChild(document.createTextNode(s));\n"
" return d.innerHTML;}\n"
"function fmtSize(n){\n"
" if(n>=1073741824)return(n/1073741824).toFixed(2)+' GB';\n"
" if(n>=1048576)return(n/1048576).toFixed(2)+' MB';\n"
" if(n>=1024)return(n/1024).toFixed(2)+' KB';\n"
" return n+' B';}\n"
"loadFiles();loadBlocks();\n"
"</script>\n"
"</body></html>\n"
